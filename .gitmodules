[submodule ".registry"]
	path = .registry
	url = https://github.com/mlverse/mlverse.r-universe.dev
	branch = HEAD
[submodule "chattr"]
	path = chattr
	url = https://github.com/mlverse/chattr
[submodule "cuda.ml"]
	path = cuda.ml
	url = https://github.com/mlverse/cuda.ml
[submodule "cuda12.6"]
	path = cuda12.6
	url = https://github.com/mlverse/cudatoolkit
	subdir = cuda12.6
[submodule "cuda12.8"]
	path = cuda12.8
	url = https://github.com/mlverse/cudatoolkit
	subdir = cuda12.8
[submodule "cuda13.2"]
	path = cuda13.2
	url = https://github.com/mlverse/cudatoolkit
	subdir = cuda13.2
[submodule "hardhat"]
	path = hardhat
	url = https://github.com/tidymodels/hardhat
	registered = false
